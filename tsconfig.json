{
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "react-native-fast-calendar": ["./src/index"],
      "react-native-fast-calendar/systems/gregorian": [
        "./src/systems/gregorian"
      ],
      "react-native-fast-calendar/systems/hijri": ["./src/systems/hijri"],
      "react-native-fast-calendar/systems/jalali": ["./src/systems/jalali"]
    },
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "customConditions": ["react-native-strict-api"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitUseStrict": false,
    "noStrictGenericChecks": false,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "types": ["jest", "node"],
    "verbatimModuleSyntax": true
  }
}
