{
  "name": "react-native-headless-calendar",
  "version": "0.1.0",
  "description": "A fast, headless, calendar-system-agnostic (Gregorian, Hijri, Jalali, or your own) React Native calendar for building fully custom date pickers, range pickers, and multi-date calendars.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./systems/gregorian": {
      "source": "./src/systems/gregorian.ts",
      "types": "./lib/typescript/src/systems/gregorian.d.ts",
      "default": "./lib/module/systems/gregorian.js"
    },
    "./systems/hijri": {
      "source": "./src/systems/hijri.ts",
      "types": "./lib/typescript/src/systems/hijri.d.ts",
      "default": "./lib/module/systems/hijri.js"
    },
    "./systems/jalali": {
      "source": "./src/systems/jalali.ts",
      "types": "./lib/typescript/src/systems/jalali.d.ts",
      "default": "./lib/module/systems/jalali.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-headless-calendar-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "oxlint && prettier --check \"**/*.{ts,tsx}\"",
    "test": "TZ=UTC jest",
    "test:coverage": "TZ=UTC jest --coverage",
    "release": "release-it --only-version"
  },
  "keywords": [
    "calendar",
    "date-picker",
    "datepicker",
    "react-native-calendar",
    "headless-calendar",
    "gregorian-calendar",
    "hijri-calendar",
    "jalali-calendar",
    "persian-calendar",
    "multi-calendar",
    "date-range-picker",
    "react-native",
    "ios",
    "android",
    "expo",
    "swipeable",
    "swipeable-calendar"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MahmoudKarout/react-native-headless-calendar.git"
  },
  "author": "karout <mahmoudtkarout@gmail.com> (https://github.com/MahmoudKarout)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MahmoudKarout/react-native-headless-calendar/issues"
  },
  "homepage": "https://github.com/MahmoudKarout/react-native-headless-calendar#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@jest/globals": "^30.0.0",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-plugin": "^0.85.3",
    "@react-native/jest-preset": "0.85.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@tabby_ai/hijri-converter": "^1.0.5",
    "@testing-library/react-native": "^13",
    "@types/jest": "^30.0.0",
    "@types/moment-jalaali": "^0.7.9",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19",
    "commitlint": "^20.5.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^30.3.0",
    "lefthook": "^2.1.4",
    "moment": "^2.30.1",
    "moment-jalaali": "^0.10.4",
    "oxlint": "^1.63.0",
    "prettier": "^3.8.1",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.41.0",
    "react-test-renderer": "19.2.0",
    "release-it": "^19.2.4",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@tabby_ai/hijri-converter": ">=1",
    "moment-jalaali": ">=0.10",
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "@tabby_ai/hijri-converter": {
      "optional": true
    },
    "moment-jalaali": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "jest": {
    "preset": "@react-native/jest-preset",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/__mocks__/"
    ],
    "globalSetup": "<rootDir>/jest.setup.ts",
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/types.ts",
      "!src/index.ts",
      "!src/components/SimpleCalendar.tsx",
      "!src/__tests__/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint",
      "jest",
      "release-it",
      "lefthook"
    ],
    "version": "0.62.0"
  }
}
